# ATLAS environment variables
# Copy this file to .env and fill in your keys.
# The system runs in mock mode if keys are absent.

# Market data — Finnhub (https://finnhub.io, free tier available)
FINNHUB_API_KEY=

# Market data — Massive (https://polygon.io, free tier available)
# Used as fallback if Finnhub key is not set.
MASSIVE_API_KEY=

# LLM scoring — Anthropic (https://console.anthropic.com)
# Required for real agent scoring and autoresearch prompt generation.
ANTHROPIC_API_KEY=
